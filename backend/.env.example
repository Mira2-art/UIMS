APP_NAME=School Backend
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/school_db
# Async SQLite fallback used automatically when Postgres is unreachable.
SQLITE_FALLBACK_URL=sqlite+aiosqlite:///./trustech.db
DB_FALLBACK_ENABLED=true
SQL_ECHO=false
AUTO_CREATE_TABLES=false
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["*"]
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
