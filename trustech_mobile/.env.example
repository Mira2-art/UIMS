# Trustech mobile environment sample.
# Copy this file to `.env` locally and replace placeholders with real values.
# Never commit the real `.env` file.

# Backend API base URL.
# Note: current app code still reads the base URL from ApiConfig, not this key.
BASE_URL=https://example.com/api/v1/mobile

# Public client identifier sent as X-Client-ID to the backend.
# Must match the backend's seeded client app (SEED_CLIENT_ID, default trustech_app).
CLIENT_ID=trustech_app

# Optional public API key placeholder if the backend enables client API keys later.
API_KEY=replace_with_non_secret_public_api_key_or_leave_blank
